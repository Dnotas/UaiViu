{
  "name": "uaiviu-food-backend",
  "version": "1.0.0",
  "description": "UaiViu Food - Backend do módulo de restaurante/delivery",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --transpile-only --respawn src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "sequelize db:migrate",
    "db:seed": "sequelize db:seed:all",
    "lint": "eslint 'src/**/*.ts'"
  },
  "dependencies": {
    "@hapi/boom": "^9.1.4",
    "@sentry/node": "^7.0.0",
    "axios": "^1.6.0",
    "baileys": "^6.7.18",
    "bcryptjs": "^2.4.3",
    "bull": "^4.10.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.1.13",
    "sequelize": "^6.32.0",
    "sequelize-typescript": "^2.1.5",
    "socket.io": "^4.6.0",
    "uuid": "^9.0.0",
    "yup": "^1.0.0"
