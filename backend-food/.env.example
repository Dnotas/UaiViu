NODE_ENV=development

# Server
PORT=3003
BACKEND_FOOD_URL=http://localhost:3003
FRONTEND_FOOD_URL=http://localhost:3002

# Banco de dados (mesmo do UaiViu principal)
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASS=
DB_NAME=

# JWT (mesmos secrets do UaiViu principal para auth compartilhada)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Redis (mesmo do UaiViu principal)
REDIS_URI=redis://:password@127.0.0.1:6379

# Upload de imagens do cardápio
UPLOADS_DIR=./uploads

# URL pública do cardápio (para enviar no WhatsApp)
# Ex: https://food.seudominio.com.br/cardapio
PUBLIC_MENU_BASE_URL=http://localhost:3002/cardapio
